#include <mega32.h>
#include <delay.h>

// 7-segment (COMMON CATHODE)
unsigned char seg[10] = {
    0x3F, 0x06, 0x5B, 0x4F, 0x66,
    0x6D, 0x7D, 0x07, 0x7F, 0x6F
};

int token_counter = 0;
int current_token = 1;
int booth1 = 0;
int booth2 = 0;

unsigned char b0 = 1, b1 = 1, b2 = 1;

int buzzer_count = 0;
#define BEEP_CYCLES 1000

// =============================================
// DISPLAY REFRESH
// Common Cathode: digit SELECT = LOW (0)
// All others = HIGH (1) to deactivate
// PORTA bits: PA0=Booth1-Tens, PA1=Booth1-Units
//             PA2=Booth2-Tens, PA3=Booth2-Units
// =============================================
void refresh_display()
{
    // --- Booth1 TENS ---
    PORTC = 0x00;                    // blank segments first
    PORTA = 0xFF;                    // all digits OFF (cathodes HIGH)
    PORTC = seg[booth1 / 10];        // load segment data
    PORTA = ~(1 << 0);               // PA0 LOW = Booth1 Tens ON
    delay_us(500);

    // --- Booth1 UNITS ---
    PORTC = 0x00;
    PORTA = 0xFF;
    PORTC = seg[booth1 % 10];
    PORTA = ~(1 << 1);               // PA1 LOW = Booth1 Units ON
    delay_us(500);

    // --- Booth2 TENS ---
    PORTC = 0x00;
    PORTA = 0xFF;
    PORTC = seg[booth2 / 10];
    PORTA = ~(1 << 2);               // PA2 LOW = Booth2 Tens ON
    delay_us(500);

    // --- Booth2 UNITS ---
    PORTC = 0x00;
    PORTA = 0xFF;
    PORTC = seg[booth2 % 10];
    PORTA = ~(1 << 3);               // PA3 LOW = Booth2 Units ON
    delay_us(500);
}

// =============================================
// NON-BLOCKING BUZZER (2 seconds)
// =============================================
void buzzer_tick()
{
    if (buzzer_count > 0)
    {
        PORTB |= (1 << 0);
        buzzer_count--;
    }
    else
    {
        PORTB &= ~(1 << 0);
    }
}

void beep_start()
{
    buzzer_count = BEEP_CYCLES;
}

// =============================================
// MAIN
// =============================================
void main()
{
    DDRA = 0xFF;     // digit selects ? output
    DDRC = 0xFF;     // segments ? output
    DDRD = 0x00;     // buttons ? input
    DDRB = 0x01;     // PB0 buzzer ? output

    PORTA = 0xFF;    // all digit cathodes HIGH = all OFF
    PORTC = 0x00;    // all segments OFF
    PORTD = 0xFF;    // internal pull-ups for buttons

    while (1)
    {
        refresh_display();
        buzzer_tick();

        // ---- TOKEN GENERATE (PD0) ----
        if (!(PIND & (1 << 0)))
        {
            if (b0)
            {
                token_counter++;
                if (token_counter > 99) token_counter = 1;
                b0 = 0;
            }
        }
        else b0 = 1;

        // ---- BOOTH 1 (PD1) ----
        if (!(PIND & (1 << 1)))
        {
            if (b1)
            {
                if (current_token <= token_counter)
                {
                    booth1 = current_token;
                    current_token++;
                    beep_start();
                }
                b1 = 0;
            }
        }
        else b1 = 1;

        // ---- BOOTH 2 (PD2) ----
        if (!(PIND & (1 << 2)))
        {
            if (b2)
            {
                if (current_token <= token_counter)
                {
                    booth2 = current_token;
                    current_token++;
                    beep_start();
                }
                b2 = 0;
            }
        }
        else b2 = 1;
    }
}
